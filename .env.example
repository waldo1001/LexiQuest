# Example env file for LexiQuest (NOT committed with real values).
# Copy to .env and fill in before running `cd api && npm run seed`.

# Azure Table Storage connection string. Local dev uses Azurite:
#   AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
# Production uses the real key from the Azure portal (rotate quarterly).
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# Seed passwords — one per family user. Only used by the one-time
# seed; after that, admins reset via the running app.
# Waldo is the admin / supervisor (hidden from the student picker).
# Lex, Mats, Ben, Kaat, Amaryllis are the student accounts shown in
# the picker, alphabetically.
PASSWORD_WALDO=
PASSWORD_LEX=
PASSWORD_MATS=
PASSWORD_BEN=
PASSWORD_KAAT=
PASSWORD_AMARYLLIS=

# Phase 3 (auth): HMAC secret for session cookies. Must be 32+ bytes.
# Rotating this logs every user out — which is the desired effect
# after a suspected leak.
SESSION_SECRET=

# Phase 12 (AI import): Anthropic API key. Tied to Waldo's personal
# billing — rotate immediately if leaked.
ANTHROPIC_API_KEY=
