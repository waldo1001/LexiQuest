{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "**/*.ts",
    "**/*.test.ts",
    "**/__integration__/**/*.ts",
    "**/__contract__/**/*.ts",
    "**/__meta__/**/*.ts"
  ]
}
