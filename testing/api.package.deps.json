{
  "_comment": "Merge these blocks into api/package.json at Phase 1. Versions are intentionally loose (caret ranges) — tighten when the project is first built and the lockfile is created.",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:unit": "vitest run --coverage --exclude '**/__integration__/**' --exclude '**/__contract__/**'",
    "test:integration": "vitest run '**/__integration__/**'",
    "test:contract": "vitest run '**/__contract__/**'",
    "test:meta": "vitest run '**/__meta__/**'",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0",
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.19.0"
  }
}
