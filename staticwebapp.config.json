{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    { "route": "/api/*" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/icons/*",
      "/manifest.json",
      "/*.webmanifest",
      "/*.{css,js,ico,svg,png,webp,woff,woff2}"
    ]
  }
}
